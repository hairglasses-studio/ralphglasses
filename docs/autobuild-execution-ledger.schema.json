{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/hairglasses-studio/ralphglasses/docs/autobuild-execution-ledger.schema.json",
  "title": "Ralphglasses Autobuild Execution Ledger",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "track",
    "repo",
    "description",
    "instructions",
    "entry_template",
    "entries"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "const": "./autobuild-execution-ledger.schema.json"
    },
    "track": {
      "type": "string",
      "const": "autobuild-execution-ledger"
    },
    "repo": {
      "type": "string",
      "const": "hairglasses-studio/ralphglasses"
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "instructions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "entry_template": {
      "$ref": "#/$defs/entry"
    },
    "entries": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/entry"
      }
    }
  },
  "$defs": {
    "trigger_signal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "source",
        "summary",
        "remote_main_verified"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["adoption", "integrity", "ci", "manual", "other"]
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "remote_main_verified": {
          "type": "boolean"
        }
      }
    },
    "evidence_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "ref",
        "summary"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["commit", "file", "ci", "test", "report", "other"]
        },
        "ref": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "closure_state",
        "summary",
        "prevented_failure_class"
      ],
      "properties": {
        "closure_state": {
          "type": "string",
          "enum": ["open", "completed", "blocked", "cancelled", "deferred"]
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "prevented_failure_class": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "date",
        "patch_id",
        "status",
        "trigger_signal",
        "repo_owned_scope",
        "recommended_entry_surface",
        "changes",
        "acceptance_condition",
        "stop_condition",
        "evidence",
        "result",
        "next_recommended_patch",
        "notes"
      ],
      "properties": {
        "date": {
          "type": "string",
          "pattern": "^(YYYY-MM-DD|[0-9]{4}-[0-9]{2}-[0-9]{2})$"
        },
        "patch_id": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": ["planned", "in_progress", "completed", "blocked", "cancelled", "deferred"]
        },
        "trigger_signal": {
          "$ref": "#/$defs/trigger_signal"
        },
        "repo_owned_scope": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "recommended_entry_surface": {
          "type": "string",
          "minLength": 1
        },
        "changes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "acceptance_condition": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "stop_condition": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "evidence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidence_item"
          }
        },
        "result": {
          "$ref": "#/$defs/result"
        },
        "next_recommended_patch": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
