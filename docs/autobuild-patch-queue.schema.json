{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/hairglasses-studio/ralphglasses/docs/autobuild-patch-queue.schema.json",
  "title": "Ralphglasses Autobuild Patch Queue",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "date",
    "repo",
    "scope",
    "source_inputs",
    "current_stance",
    "patch_selection_rules",
    "ranked_queue",
    "out_of_scope",
    "handoff_format",
    "first_recommended_execution_order"
  ],
  "properties": {
    "date": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "repo": {
      "type": "string",
      "const": "hairglasses-studio/ralphglasses"
    },
    "scope": {
      "type": "string",
      "minLength": 1
    },
    "source_inputs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "current_stance": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "patch_selection_rules": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "ranked_queue": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "rank",
          "id",
          "priority",
          "why_now",
          "recommended_scope",
          "acceptance"
        ],
        "properties": {
          "rank": { "type": "integer", "minimum": 1 },
          "id": { "type": "string", "minLength": 1 },
          "priority": { "type": "string", "pattern": "^P[0-2]$" },
          "why_now": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "minItems": 1
          },
          "recommended_scope": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "minItems": 1
          },
          "acceptance": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "minItems": 1
          }
        }
      }
    },
    "out_of_scope": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "handoff_format": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "first_recommended_execution_order": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    }
  }
}
