.TH "RALPHGLASSES" "1" "Apr 2026" "ralphglasses" ""

.SH NAME
ralphglasses-debug-bundle - Collect diagnostic information into a text bundle


.SH SYNOPSIS
\fBralphglasses debug-bundle [flags]\fP


.SH DESCRIPTION
Gather system information, configuration, and logs into a single diagnostic
file for troubleshooting. API keys and secrets are automatically masked.

.PP
The bundle includes:
  - Go and git versions, OS info
  - ralphglasses version and configuration
  - .ralphrc contents (sanitized)
  - Recent log output
  - Doctor check results


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for debug-bundle

.PP
\fB-o\fP, \fB--output\fP=""
	Output file path (default: ralph-debug-TIMESTAMP.txt in current directory)


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--debug\fP[=false]
	Enable verbose debug logging to stderr

.PP
\fB--http-addr\fP=""
	Enable health endpoints on this address (e.g. :9090, disabled by default)

.PP
\fB--log-format\fP="json"
	Log format (json, text)

.PP
\fB--log-level\fP="info"
	Log level (debug, info, warn, error)

.PP
\fB--scan-path\fP="~/hairglasses-studio"
	Root directory to scan for ralph-enabled repos

.PP
\fB--scan-timeout\fP="30s"
	Timeout for repository scanning (e.g. 30s, 1m)

.PP
\fB--web-addr\fP=""
	Enable web UI on this address (e.g. :8080, disabled by default). Set RALPHGLASSES_WEB_TOKEN for auth.


.SH EXAMPLE
.EX
  # Create a debug bundle in the current directory
  ralphglasses debug-bundle

  # Specify output path
  ralphglasses debug-bundle --output /tmp/diag.txt
.EE


.SH SEE ALSO
\fBralphglasses(1)\fP


