.TH "RALPHGLASSES" "1" "Apr 2026" "ralphglasses" ""

.SH NAME
ralphglasses-init - Generate a default .ralphrc configuration file


.SH SYNOPSIS
\fBralphglasses init [directory] [flags]\fP


.SH DESCRIPTION
Create a .ralphrc configuration file in the specified directory (or current
directory if none given). The generated file contains documented configuration
keys with sensible defaults.

.PP
Use --minimal to generate a bare-minimum config with only required keys.
Use --force to overwrite an existing .ralphrc file.


.SH OPTIONS
\fB--force\fP[=false]
	Overwrite existing .ralphrc file

.PP
\fB-h\fP, \fB--help\fP[=false]
	help for init

.PP
\fB--minimal\fP[=false]
	Generate minimal config with only required keys


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--debug\fP[=false]
	Enable verbose debug logging to stderr

.PP
\fB--http-addr\fP=""
	Enable health endpoints on this address (e.g. :9090, disabled by default)

.PP
\fB--log-format\fP="json"
	Log format (json, text)

.PP
\fB--log-level\fP="info"
	Log level (debug, info, warn, error)

.PP
\fB--scan-path\fP="~/hairglasses-studio"
	Root directory to scan for ralph-enabled repos

.PP
\fB--scan-timeout\fP="30s"
	Timeout for repository scanning (e.g. 30s, 1m)

.PP
\fB--web-addr\fP=""
	Enable web UI on this address (e.g. :8080, disabled by default). Set RALPHGLASSES_WEB_TOKEN for auth.


.SH EXAMPLE
.EX
  # Initialize in the current directory
  ralphglasses init

  # Initialize in a specific project directory
  ralphglasses init ~/projects/myrepo

  # Overwrite existing .ralphrc
  ralphglasses init --force

  # Minimal config (only required keys)
  ralphglasses init --minimal
.EE


.SH SEE ALSO
\fBralphglasses(1)\fP


