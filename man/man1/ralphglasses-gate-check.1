.TH "RALPHGLASSES" "1" "Apr 2026" "ralphglasses" ""

.SH NAME
ralphglasses-gate-check - Evaluate regression gates against loop observations


.SH SYNOPSIS
\fBralphglasses gate-check [flags]\fP


.SH DESCRIPTION
Load recent loop observations and evaluate them against a baseline.
Exits 0 on pass/warn/skip, exits 1 on fail.


.SH OPTIONS
\fB--baseline\fP=""
	path to baseline JSON (default: .ralph/loop_baseline.json)

.PP
\fB-h\fP, \fB--help\fP[=false]
	help for gate-check

.PP
\fB--hours\fP=24
	look-back window in hours

.PP
\fB--json\fP[=false]
	output JSON for automation


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--debug\fP[=false]
	Enable verbose debug logging to stderr

.PP
\fB--http-addr\fP=""
	Enable health endpoints on this address (e.g. :9090, disabled by default)

.PP
\fB--log-format\fP="json"
	Log format (json, text)

.PP
\fB--log-level\fP="info"
	Log level (debug, info, warn, error)

.PP
\fB--scan-path\fP="~/hairglasses-studio"
	Root directory to scan for ralph-enabled repos

.PP
\fB--scan-timeout\fP="30s"
	Timeout for repository scanning (e.g. 30s, 1m)

.PP
\fB--web-addr\fP=""
	Enable web UI on this address (e.g. :8080, disabled by default). Set RALPHGLASSES_WEB_TOKEN for auth.


.SH EXAMPLE
.EX
  # Check against saved baseline
  ralphglasses gate-check --baseline .ralph/loop_baseline.json --hours 24

  # JSON output for automation
  ralphglasses gate-check --json --hours 24

  # Check with default baseline path
  ralphglasses gate-check
.EE


