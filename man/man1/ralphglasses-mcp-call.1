.TH "RALPHGLASSES" "1" "Apr 2026" "ralphglasses" ""

.SH NAME
ralphglasses-mcp-call - Call an MCP tool directly and print the result


.SH SYNOPSIS
\fBralphglasses mcp-call  [--param key=value ...] [flags]\fP


.SH DESCRIPTION
Invoke a registered MCP tool in-process without starting a full MCP server.
Useful for scripts, CI pipelines, and quick one-off tool invocations.

.PP
Parameters are passed as repeatable -p key=value flags. Values are
auto-detected as numbers, booleans, or strings.


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for mcp-call

.PP
\fB-p\fP, \fB--param\fP=[]
	Tool parameter as key=value (repeatable)


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--debug\fP[=false]
	Enable verbose debug logging to stderr

.PP
\fB--http-addr\fP=""
	Enable health endpoints on this address (e.g. :9090, disabled by default)

.PP
\fB--log-format\fP="json"
	Log format (json, text)

.PP
\fB--log-level\fP="info"
	Log level (debug, info, warn, error)

.PP
\fB--scan-path\fP="~/hairglasses-studio"
	Root directory to scan for ralph-enabled repos

.PP
\fB--scan-timeout\fP="30s"
	Timeout for repository scanning (e.g. 30s, 1m)

.PP
\fB--web-addr\fP=""
	Enable web UI on this address (e.g. :8080, disabled by default). Set RALPHGLASSES_WEB_TOKEN for auth.


.SH EXAMPLE
.EX
  # Scan for repos
  ralphglasses mcp-call ralphglasses_scan

  # Run self-improvement with budget
  ralphglasses mcp-call ralphglasses_self_improve -p repo=myrepo -p budget_usd=10

  # Check fleet status
  ralphglasses mcp-call ralphglasses_fleet_status
.EE


