.TH "RALPHGLASSES" "1" "Apr 2026" "ralphglasses" ""

.SH NAME
ralphglasses-completion - Generate shell completion scripts


.SH SYNOPSIS
\fBralphglasses completion [bash|zsh|fish] [flags]\fP


.SH DESCRIPTION
Generate shell completion scripts for ralphglasses.

.PP
To install completions:

.PP
Bash:
    ralphglasses completion bash > /etc/bash_completion.d/ralphglasses
    # or for current user:
    ralphglasses completion bash > ~/.bash_completion

.PP
Zsh:
    ralphglasses completion zsh > "${fpath[1]}/_ralphglasses"
    # or add to ~/.zshrc:
    source <(ralphglasses completion zsh)

.PP
Fish:
    ralphglasses completion fish > ~/.config/fish/completions/ralphglasses.fish


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for completion


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--debug\fP[=false]
	Enable verbose debug logging to stderr

