.TH "RALPHGLASSES" "1" "Apr 2026" "ralphglasses" ""

.SH NAME
ralphglasses-marathon - Run continuous improvement cycles with budget and time limits


.SH SYNOPSIS
\fBralphglasses marathon [flags]\fP


.SH DESCRIPTION
Launch a marathon supervisor session that runs improvement cycles
until the budget or duration limit is reached.

.PP
Checkpoints are saved at the specified interval for resumability.


.SH OPTIONS
\fB--budget\fP=10
	Maximum budget in USD

.PP
\fB--checkpoint-interval\fP="10m"
	Checkpoint save interval (e.g. 5m, 10m)

.PP
\fB--duration\fP="1h"
	Maximum duration (e.g. 1h, 30m, 2h)

.PP
\fB-h\fP, \fB--help\fP[=false]
	help for marathon

.PP
\fB--repo\fP=""
	Target repository path (default: /ralphglasses)

.PP
\fB--resume\fP[=false]
	Resume from previous supervisor state


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--debug\fP[=false]
	Enable verbose debug logging to stderr

.PP
\fB--http-addr\fP=""
	Enable health endpoints on this address (e.g. :9090, disabled by default)

.PP
\fB--log-format\fP="json"
	Log format (json, text)

.PP
\fB--log-level\fP="info"
	Log level (debug, info, warn, error)

.PP
\fB--scan-path\fP="~/hairglasses-studio"
	Root directory to scan for ralph-enabled repos

.PP
\fB--scan-timeout\fP="30s"
	Timeout for repository scanning (e.g. 30s, 1m)

.PP
\fB--web-addr\fP=""
	Enable web UI on this address (e.g. :8080, disabled by default). Set RALPHGLASSES_WEB_TOKEN for auth.


