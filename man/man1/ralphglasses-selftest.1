.nh
.TH "RALPHGLASSES" "1" "Apr 2026" "ralphglasses" ""

.SH NAME
ralphglasses-selftest - Run recursive self-test iterations and evaluate regression gates


.SH SYNOPSIS
\fBralphglasses selftest [flags]\fP


.SH DESCRIPTION
Run self-test iterations against the current repository and evaluate
regression gates against a baseline. In --gate mode, only evaluates the
gate without running iterations.

.PP
Exits 0 on pass/warn/skip, exits 1 on fail.


.SH OPTIONS
\fB--budget\fP=2
	API budget in USD

.PP
\fB--dry-run\fP[=false]
	validate config and print summary without running iterations

.PP
\fB--gate\fP[=false]
	gate-check only, skip iterations

.PP
\fB-h\fP, \fB--help\fP[=false]
	help for selftest

.PP
\fB--iterations\fP=2
	number of self-test iterations

.PP
\fB--json\fP[=false]
	output JSON for automation

.PP
\fB--repo-path\fP="."
	repository path to test


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--debug\fP[=false]
	Enable verbose debug logging to stderr

.PP
\fB--http-addr\fP=""
	Enable health endpoints on this address (e.g. :9090, disabled by default)

.PP
\fB--log-format\fP="json"
	Log format (json, text)

.PP
\fB--log-level\fP="info"
	Log level (debug, info, warn, error)

.PP
\fB--scan-path\fP="~/hairglasses-studio"
	Root directory to scan for ralph-enabled repos

.PP
\fB--scan-timeout\fP="30s"
	Timeout for repository scanning (e.g. 30s, 1m)

.PP
\fB--web-addr\fP=""
	Enable web UI on this address (e.g. :8080, disabled by default). Set RALPHGLASSES_WEB_TOKEN for auth.


.SH EXAMPLE
.EX
  # Run 2 iterations with $2 budget
  ralphglasses selftest --iterations 2 --budget 2.0

  # Gate-check only (no iterations)
  ralphglasses selftest --gate

  # Validate config without running
  ralphglasses selftest --dry-run

  # Override budget for CI
  ralphglasses selftest --budget 1.0

  # JSON output for CI
  ralphglasses selftest --gate --json
.EE


.SH SEE ALSO
\fBralphglasses(1)\fP


