func TestSessionTriage_NoSessions(t *testing.T) {
	t.Parallel()
	s := &Server{
		SessMgr: session.NewManager(),
	}
	req := mcp.CallToolRequest{}
	req.Params.Arguments = map[string]any{"since": "1h"}

	result, err := s.handleSessionTriage(context.Background(), req)
	if err != nil {
		t.Fatal(err)
	}
	text := result.Content[0].(mcp.TextContent).Text
	if !containsCI(text, "\"total_sessions\":0") && !containsCI(text, "\"total_sessions\": 0") {
		t.Errorf("expected 0 sessions in empty triage, got: %s", text)
	}
}

