func TestParseTimeParam_Relative(t *testing.T) {
	t.Parallel()
	now := time.Now()

	t1, err := parseTimeParam("2h", 0)
	if err != nil {
		t.Fatal(err)
	}
	if now.Sub(t1) < time.Hour || now.Sub(t1) > 3*time.Hour {
		t.Errorf("2h should be ~2 hours ago, got %v ago", now.Sub(t1))
	}

	t2, err := parseTimeParam("1d", 0)
	if err != nil {
		t.Fatal(err)
	}
	if now.Sub(t2) < 23*time.Hour || now.Sub(t2) > 25*time.Hour {
		t.Errorf("1d should be ~24 hours ago, got %v ago", now.Sub(t2))
	}
}

func TestParseTimeParam_RFC3339(t *testing.T) {
	t.Parallel()
	ts := "2026-04-05T01:00:00Z"
	got, err := parseTimeParam(ts, 0)
	if err != nil {
		t.Fatal(err)
	}
	want, _ := time.Parse(time.RFC3339, ts)
	if !got.Equal(want) {
		t.Errorf("got %v, want %v", got, want)
	}
}

func TestParseTimeParam_Invalid(t *testing.T) {
	t.Parallel()
	_, err := parseTimeParam("garbage", 0)
	if err == nil {
		t.Error("expected error for invalid time string")
	}
}

func TestParseTimeParam_Empty(t *testing.T) {
	t.Parallel()
	now := time.Now()
	got, err := parseTimeParam("", time.Hour)
	if err != nil {
		t.Fatal(err)
	}
	if now.Sub(got) < 50*time.Minute || now.Sub(got) > 70*time.Minute {
		t.Errorf("empty with 1h default should be ~1h ago, got %v ago", now.Sub(got))
	}
}

func TestClassifySessionKillReason(t *testing.T) {
	t.Parallel()
	tests := []struct {
		name  string
		error string
		want  string
	}{
		{"oom", "out of memory", "oom"},
		{"timeout", "deadline exceeded", "timeout"},
		{"signal", "signal: killed", "signal_killed"},
		{"budget", "budget exceeded", "budget_exceeded"},
		{"rate", "429 too many requests", "rate_limited"},
		{"network", "connection reset", "network_error"},
		{"unknown", "some random error", "other"},
		{"empty", "", "unknown"},
	}
	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			sess := &session.Session{Error: tt.error}
			got := classifySessionKillReason(sess)
			if got != tt.want {
				t.Errorf("classifySessionKillReason(%q) = %q, want %q", tt.error, got, tt.want)
			}
		})
	}
}

func TestClassifySalvage(t *testing.T) {
	t.Parallel()
	tests := []struct {
		name   string
		sess   *session.Session
		want   string
	}{
		{"no output", &session.Session{}, "no_useful_output"},
		{"has turns", &session.Session{TurnCount: 3}, "partial_completion"},
		{"nearly done", &session.Session{TurnCount: 9, MaxTurns: 10}, "nearly_complete"},
		{"has commit output", &session.Session{LastOutput: "Successfully committed changes"}, "partial_completion"},
	}
	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			got := classifySalvage(tt.sess)
			if got != tt.want {
				t.Errorf("classifySalvage = %q, want %q", got, tt.want)
			}
		})
	}
}
