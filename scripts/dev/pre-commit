#!/usr/bin/env bash
set -euo pipefail

echo "Running pre-commit checks..."

echo "→ tracked artifact gate"
bash ./scripts/dev/check-tracked-artifacts.sh

echo "→ generated surface drift gate"
bash ./scripts/dev/check-generated-surfaces.sh

echo "→ go vet"
go vet ./...

echo "→ go test -short"
go test -short -count=1 ./...

echo "✓ All checks passed"
