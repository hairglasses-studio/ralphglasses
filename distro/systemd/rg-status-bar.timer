# rg-status-bar.timer — Periodic fleet status refresh
#
# Triggers rg-status-bar.service every 30 seconds to keep the
# i3blocks status bar cache fresh.
#
# TODO: Enable via `systemctl --user enable --now rg-status-bar.timer`
# TODO: Add to distro firstboot or hw-detect.sh post-setup

[Unit]
Description=Refresh ralphglasses fleet status every 30s

[Timer]
OnBootSec=10
OnUnitActiveSec=30

[Install]
WantedBy=timers.target
